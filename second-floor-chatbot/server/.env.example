# 複製成 .env 並填入你的 key(.env 已被 gitignore,不會進版控)
# Key 從 Google AI Studio 取得:https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-aistudio-api-key-here

# 主力 Flash-Lite;要升級改成 gemini-2.5-flash 或 gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash-lite

# 允許的前端來源(CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
