# 複製成 .env 並填入你的設定(.env 已被 gitignore,不會進版控)

# 對話引擎 provider 的「首次啟動種子」:gemini | openai
# 註:provider 設定改由 /admin 管理介面維護並存進 SQLite(可多筆、可隨時切換)。
# 下方 LLM_PROVIDER / *_API_KEY / *_MODEL 只在「資料庫尚無任何 provider」時用來建立預設資料。
LLM_PROVIDER=gemini

# ── 管理介面密碼(/admin 登入用,務必改掉) ──
ADMIN_TOKEN=change-me

# ── Gemini provider ──
# Key 從 Google AI Studio 取得:https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-aistudio-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# ── OpenAI 相容 provider(自架 vLLM / lab / 任何 OpenAI 相容 endpoint）──
OPENAI_API_KEY=your-openai-compatible-key
OPENAI_BASE_URL=https://your-endpoint/v1
OPENAI_MODEL=openai/Qwen3.5-122B-A10B

# 允許的前端來源(CORS）
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 部署設定 ──
# Zeabur 上請設為掛載 Persistent Volume 路徑,避免重啟清空資料:SF_DB_PATH=/data/app.db
# 本機開發不需設定(預設 app/data/app.db)
# SF_DB_PATH=/data/app.db

# Per-IP 速率限制(每 60 秒最多幾次請求,預設 60)
# RATE_LIMIT=60
